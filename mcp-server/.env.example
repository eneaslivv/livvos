# ── LIVV OS MCP server env ──────────────────────────────────────
# Copy this to `.env` (or set these in your MCP client config) and
# fill in real values. The server fails fast on boot if any are
# missing.

# Supabase project URL (full URL, no trailing slash)
SUPABASE_URL=https://ngswutcpsgdgmmjnfddi.supabase.co

# Service role key — bypasses RLS, so the MCP has full admin access.
# This is intended for personal/owner use. NEVER share this key.
# Find it in: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Tenant id to scope every query to. All reads/writes are filtered
# by this tenant so the MCP can never accidentally touch another
# workspace. Find yours via the SQL editor:
#   select id, name from tenants where name = 'Principal Admin';
LIVVOS_TENANT_ID=309be231-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional — the user_id that "create_*" operations attribute as the
# owner / creator. If unset, falls back to the first platform admin.
LIVVOS_OWNER_USER_ID=

# Optional — anon key + a user JWT to call edge functions like
# `ask_advisor` (which needs a real user session). If unset, the
# AI tools are disabled but everything else works.
SUPABASE_ANON_KEY=
LIVVOS_USER_JWT=
