{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite dev (main app)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Vite preview (production build)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173
    },
    {
      "name": "livv-mission-control (portal sub-app)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "components/portal/livv-client view-control"],
      "port": 3001
    }
  ]
}
