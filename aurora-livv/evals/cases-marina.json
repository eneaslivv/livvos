{
  "agent": "marina",
  "model": "claude-sonnet-4-6",
  "tenant_id": "11111111-1111-1111-1111-111111111111",
  "user_id": "22222222-2222-2222-2222-222222222222",
  "cases": [
    {
      "id": "mar-001-monthly-snapshot",
      "user_message": "¿cómo va mi mes?",
      "assertions": {
        "must_emit_canvas": "display",
        "canvas_required_blocks": ["stat_cards"],
        "must_mention_currency_symbol": true,
        "must_not_invent_numbers": true
      }
    },
    {
      "id": "mar-002-project-in-loss",
      "user_message": "qué proyectos están en pérdida",
      "assertions": {
        "must_mention": ["Fintech Dashboard", "Bank Corp"],
        "must_emit_canvas": "display",
        "canvas_required_blocks": ["project_grid"]
      }
    },
    {
      "id": "mar-003-explain-loss-driver",
      "user_message": "por qué está en pérdida el de Bank Corp?",
      "assertions": {
        "must_mention_one_of": ["collection", "expense", "hour", "scope"],
        "must_not_invent_numbers": true,
        "max_length_chars": 600
      }
    },
    {
      "id": "mar-004-cannot-set-health-directly",
      "user_message": "marcá el de Bank Corp como break-even",
      "assertions": {
        "must_mention": ["trigger", "no puedo", "recalcula"],
        "must_not_emit_canvas": "workflow"
      },
      "notes": "health is GENERATED by trigger"
    },
    {
      "id": "mar-005-reclassify-expense",
      "user_message": "Mové 400 de imputado a directo en el proyecto de SaaS Branding",
      "assertions": {
        "must_emit_canvas": "workflow",
        "canvas_required_blocks": ["diff"],
        "must_show_margin_delta": true
      }
    },
    {
      "id": "mar-006-currency-format",
      "user_message": "cuánto cobré este mes",
      "assertions": {
        "must_mention_currency_symbol": true,
        "must_format_money_two_decimals": true,
        "must_not_invent_numbers": true
      }
    },
    {
      "id": "mar-007-ar-aging",
      "user_message": "AR aging",
      "assertions": {
        "must_emit_canvas": "display",
        "canvas_required_blocks": ["stat_cards", "bar_chart"],
        "must_mention": ["0-30", "31-60", "61-90", "90+"]
      }
    },
    {
      "id": "mar-008-cash-projection",
      "user_message": "cuánto voy a cobrar las próximas 12 semanas",
      "assertions": {
        "must_emit_canvas": "display",
        "must_mention": ["proyección", "depende"],
        "must_show_uncertainty_disclaimer": true
      }
    },
    {
      "id": "mar-009-invoice-from-won-lead",
      "user_message": "Cobremos a Lucía Méndez",
      "assertions": {
        "must_emit_canvas": "workflow",
        "canvas_required_blocks": ["stepper", "diff"],
        "must_mention": ["borrador", "factura"]
      }
    },
    {
      "id": "mar-010-invoice-not-accepted-blocks",
      "user_message": "Cobremos a Diego López",
      "assertions": {
        "must_not_emit_canvas": "workflow",
        "must_mention": ["accepted", "aceptada", "primero"]
      },
      "notes": "Diego is still in negotiation, no accepted proposal"
    },
    {
      "id": "mar-011-no-runway-claim",
      "user_message": "Cuánto runway me queda",
      "assertions": {
        "must_mention": ["no", "Livv", "expenses", "gastos"],
        "must_not_invent_numbers": true
      },
      "notes": "Livv v1 has no company-level expenses to compute runway"
    },
    {
      "id": "mar-012-business-model-validation",
      "user_message": "Cambiá el SaaS Branding a 'subscription'",
      "assertions": {
        "must_mention_one_of": ["fixed", "hourly", "retainer", "no válido"],
        "must_not_emit_canvas": "workflow"
      }
    },
    {
      "id": "mar-013-no-emoji-money",
      "user_message": "cuánto facturé este año",
      "assertions": {
        "must_not_use_emojis": true,
        "must_mention_currency_symbol": true
      }
    },
    {
      "id": "mar-014-tenant-revenue-ytd",
      "user_message": "Revenue 2026",
      "assertions": {
        "must_emit_canvas": "display",
        "canvas_required_blocks": ["stat_cards"],
        "must_mention": ["2026"]
      }
    },
    {
      "id": "mar-015-not-yet-billed-annotation",
      "user_message": "estado del Editorial Site",
      "assertions": {
        "must_mention": ["Editorial", "billed", "facturad", "0"],
        "must_emit_canvas": "display"
      },
      "notes": "Editorial Site has total_collected=0"
    },
    {
      "id": "mar-016-cross-domain-deflect-sales",
      "user_message": "qué lead está más caliente",
      "assertions": {
        "must_mention": ["Solara"],
        "max_length_chars": 200
      }
    },
    {
      "id": "mar-017-currency-mismatch-refuse",
      "user_message": "Sumá 5000 EUR al de Tech Store",
      "assertions": {
        "must_mention_one_of": ["moneda", "currency", "tenant"],
        "must_not_emit_canvas": "workflow"
      },
      "notes": "Tenant default is USD; mixed-currency single project should refuse"
    },
    {
      "id": "mar-018-rounding-discipline",
      "user_message": "margen exacto del proyecto SaaS Branding",
      "assertions": {
        "must_format_money_two_decimals": true,
        "must_not_invent_numbers": true
      }
    }
  ]
}
