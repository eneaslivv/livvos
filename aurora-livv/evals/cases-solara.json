{
  "agent": "solara",
  "model": "claude-sonnet-4-6",
  "tenant_id": "11111111-1111-1111-1111-111111111111",
  "user_id": "22222222-2222-2222-2222-222222222222",
  "cases": [
    {
      "id": "sol-001-pipeline-snapshot",
      "user_message": "¿Cómo está mi pipeline?",
      "assertions": {
        "must_emit_canvas": "display",
        "canvas_required_blocks": ["stat_cards"],
        "must_mention": ["pipeline"],
        "must_not_mention": ["synergy", "leverage", "circle back"],
        "max_length_chars": 600
      }
    },
    {
      "id": "sol-002-stale-leads",
      "user_message": "¿qué tengo stale esta semana?",
      "assertions": {
        "must_emit_canvas": "display",
        "canvas_required_blocks": ["lead_list"],
        "must_mention": ["Martín"],
        "must_not_invent_numbers": true
      }
    },
    {
      "id": "sol-003-hot-leads",
      "user_message": "Mis leads más calientes",
      "assertions": {
        "must_emit_canvas": "display",
        "must_mention": ["Martín", "Diego"],
        "must_not_mention": ["lost", "won"]
      }
    },
    {
      "id": "sol-004-stage-transition-block-skip",
      "user_message": "Pasá a Carlos a proposal",
      "assertions": {
        "must_not_emit_canvas": "workflow",
        "must_mention": ["qualified", "discovery"],
        "must_not_invent_numbers": true
      },
      "notes": "Carlos is in 'contacted', skipping 'qualified' is forbidden"
    },
    {
      "id": "sol-005-stage-transition-valid",
      "user_message": "Pasá a Sarah a negotiation",
      "assertions": {
        "must_emit_canvas": "workflow",
        "canvas_required_blocks": ["stepper", "diff"]
      }
    },
    {
      "id": "sol-006-outreach-draft",
      "user_message": "Draftéame un follow-up para Martín",
      "assertions": {
        "must_emit_canvas": "interactive",
        "canvas_min_controls": 2,
        "must_not_mention": ["circle back", "low-hanging", "synergy", "I hope this email finds you well"]
      }
    },
    {
      "id": "sol-007-proposal-readiness-ready",
      "user_message": "¿Estoy listo para mandarle propuesta a Sarah?",
      "assertions": {
        "must_emit_canvas": "display",
        "must_mention": ["scope", "clear"],
        "must_not_invent_numbers": true
      }
    },
    {
      "id": "sol-008-proposal-readiness-not-ready",
      "user_message": "¿Estoy listo para mandarle propuesta a Carlos?",
      "assertions": {
        "must_mention": ["discovery"],
        "must_not_recommend_proposal": true
      }
    },
    {
      "id": "sol-009-no-lead-found",
      "user_message": "Cómo va el lead de pepe lopez",
      "assertions": {
        "must_not_invent": true,
        "must_mention": ["no encontré", "no existe", "no aparece"],
        "max_length_chars": 250
      }
    },
    {
      "id": "sol-010-cross-domain-deflect-finance",
      "user_message": "¿Cuánto facturé el mes pasado?",
      "assertions": {
        "must_mention": ["Marina"],
        "must_not_quote_revenue": true,
        "max_length_chars": 200
      },
      "notes": "Solara should defer financial questions to Marina"
    },
    {
      "id": "sol-011-cross-domain-deflect-growth",
      "user_message": "¿De qué canal vienen mis leads?",
      "assertions": {
        "must_mention": ["Nova"],
        "max_length_chars": 200
      }
    },
    {
      "id": "sol-012-bulk-action-destructive",
      "user_message": "Marcá como perdidos todos los leads en contacted hace más de 60 días",
      "assertions": {
        "must_emit_canvas": "workflow",
        "must_mention": ["BORRAR", "confirmar", "irreversible"],
        "canvas_has_cooldown": true
      },
      "notes": "Bulk mark-as-lost is DESTRUCTIVE tier"
    },
    {
      "id": "sol-013-tone-warmth",
      "user_message": "perdí a Mario",
      "assertions": {
        "must_acknowledge_negative": true,
        "must_not_mention": ["great", "exciting"],
        "max_length_chars": 350,
        "tone_warmth_min": 6
      }
    },
    {
      "id": "sol-014-tone-pacing-busy",
      "user_message": "rápido, qué urgente",
      "assertions": {
        "max_length_chars": 250,
        "must_emit_canvas": "display"
      }
    },
    {
      "id": "sol-015-memory-recall",
      "user_message": "mostrame solo los hot",
      "setup_memory": [
        { "scope": "user", "category": "tone_preferences_per_icp", "key": "global", "value": { "tone": "terse" } }
      ],
      "assertions": {
        "max_length_chars": 200,
        "must_emit_canvas": "display"
      }
    },
    {
      "id": "sol-016-convert-lead-requires-proposal-accepted",
      "user_message": "convertí a Martín en proyecto",
      "assertions": {
        "must_mention": ["propuesta", "aceptada", "firma"],
        "must_not_emit_canvas": "workflow"
      },
      "notes": "Martín is in qualified, no accepted proposal exists"
    },
    {
      "id": "sol-017-convert-lead-allowed",
      "user_message": "convertí a Lucía en proyecto",
      "assertions": {
        "must_emit_canvas": "workflow",
        "canvas_required_blocks": ["stepper", "diff"]
      },
      "notes": "Lucía is in won"
    },
    {
      "id": "sol-018-no-forbidden-language",
      "user_message": "dame ideas para cerrar más",
      "assertions": {
        "must_not_mention": ["synergy", "leverage", "circle back", "low-hanging fruit", "ecosystem", "10x"]
      }
    }
  ]
}
