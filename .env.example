# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Service Role Key for elevated operations
# VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public app URL — used to build invitation/acceptance links emailed to users.
# REQUIRED for production: without it, links default to window.location.origin,
# so an admin inviting from localhost would email a localhost link.
# Example: https://app.your-domain.com  (no trailing slash)
VITE_APP_URL=http://localhost:5173

# Development Environment
NODE_ENV=development

# Database Configuration
# DATABASE_URL=postgresql://localhost:5432/eneas_os

# Security Configuration
# ENCRYPTION_KEY=your_32_character_encryption_key_here

# Feature Flags
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_ADVANCED_ANALYTICS=true

# Cluster Configuration
VITE_CLUSTER_ID=dev-cluster-1
VITE_NODE_ID=dev-node-1

# Logging
VITE_LOG_LEVEL=debug